{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "g2f/client-marquee",
	"version": "1.0.0",
	"title": "Client Logos Marquee",
	"category": "widgets",
	"icon": "building",
	"description": "Display client logos in a marquee/carousel format.",
	"keywords": ["clients", "logos", "partners", "marquee", "carousel"],
	"textdomain": "g2f-functionality",
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"attributes": {
		"postsPerPage": {
			"type": "number",
			"default": 20
		},
		"speed": {
			"type": "number",
			"default": 30
		},
		"pauseOnHover": {
			"type": "boolean",
			"default": true
		},
		"direction": {
			"type": "string",
			"default": "left"
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
